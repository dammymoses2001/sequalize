# Supabase (pick one approach)

# Option 1: Connection string from Supabase Dashboard → Project Settings → Database
# Use "Connection string" → "URI" (Transaction pooler recommended for serverless)
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Option 2: Individual variables (from same Database settings page)
# SUPABASE_DB_HOST=db.<project-ref>.supabase.co
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_DB_PORT=5432

# Optional: set to "false" to disable SSL (not recommended for Supabase)
# DATABASE_SSL=false
